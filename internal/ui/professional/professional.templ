package professional

import "appointment-manager/internal/ui/layout"

templ Dashboard() {
    @layout.Base("Professional Dashboard", true) {
        <div class="text-center">
            <h1 class="text-4xl font-bold mb-4">Welcome to Your Professional Dashboard</h1>
            <p class="text-lg text-gray-600">Manage your appointments and clients efficiently.</p>
        </div>
    }
}